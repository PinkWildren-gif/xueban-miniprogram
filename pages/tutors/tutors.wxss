/* pages/tutors/tutors.wxss */

.search-bar {
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-bottom: 1px solid #F3F4F6;
}

.search-input {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.chip-row {
  white-space: nowrap;
  background: #ffffff;
  padding: 16rpx 24rpx;
  border-bottom: 1px solid #F9FAFB;
}

.chip {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  background: #F3F4F6;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #4B5563;
}

.chip.active {
  background: #1a5d3a;
  color: #ffffff;
  font-weight: 600;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-bottom: 1px solid #F3F4F6;
}

.count {
  font-size: 26rpx;
  color: #6B7280;
}

.bold { font-weight: 700; }

.sort-picker {
  font-size: 24rpx;
  color: #1a5d3a;
  padding: 8rpx 16rpx;
  background: #F0FDF4;
  border-radius: 12rpx;
}

.tutor-list {
  padding: 24rpx;
}

.tutor-card {
  padding: 24rpx;
}

.tutor-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tutor-info {
  flex: 1;
  min-width: 0;
}

.tutor-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.name-text {
  font-weight: 700;
  font-size: 30rpx;
}

.tutor-school {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tutor-meta {
  font-size: 22rpx;
  color: #6b7280;
}

.rating {
  color: #D97706;
  font-weight: 600;
}

.fav-btn {
  font-size: 36rpx;
  padding: 8rpx;
}

.book-badge {
  background: #FEF3C7;
  border-left: 4rpx solid #F59E0B;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #92400E;
  margin-bottom: 16rpx;
}

.tutor-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 16rpx;
  border-top: 1px solid #F3F4F6;
}

.price {
  font-size: 36rpx;
  font-weight: 700;
}

.price-l {
  font-size: 22rpx;
  color: #9CA3AF;
}

.district {
  font-size: 22rpx;
  color: #6b7280;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #1a5d3a;
  text-decoration: underline;
}
