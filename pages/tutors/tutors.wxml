<!-- pages/tutors/tutors.wxml -->
<view class="search-bar">
  <input
    class="search-input"
    placeholder="搜索老师、学校、学科..."
    value="{{searchText}}"
    bindinput="onSearchInput"
    confirm-type="search"
  />
</view>

<!-- Filter chips row 1: subject category -->
<scroll-view scroll-x class="chip-row">
  <view
    class="chip {{activeCat === 'all' ? 'active' : ''}}"
    data-val="all"
    bindtap="setCategory"
  >全部</view>
  <view
    class="chip {{activeCat === '学科' ? 'active' : ''}}"
    data-val="学科"
    bindtap="setCategory"
  >📖 学科辅导</view>
  <view
    class="chip {{activeCat === '艺术' ? 'active' : ''}}"
    data-val="艺术"
    bindtap="setCategory"
  >🎨 艺术音乐</view>
  <view
    class="chip {{activeCat === '素质' ? 'active' : ''}}"
    data-val="素质"
    bindtap="setCategory"
  >🌱 素质教育</view>
</scroll-view>

<!-- Filter row 2: grade -->
<scroll-view scroll-x class="chip-row">
  <view
    class="chip {{activeGrade === 'all' ? 'active' : ''}}"
    data-val="all"
    bindtap="setGrade"
  >全部年级</view>
  <view
    wx:for="{{grades}}"
    wx:key="*this"
    class="chip {{activeGrade === item ? 'active' : ''}}"
    data-val="{{item}}"
    bindtap="setGrade"
  >{{item}}</view>
</scroll-view>

<!-- Filter row 3: district -->
<scroll-view scroll-x class="chip-row">
  <view
    class="chip {{activeDistrict === 'all' ? 'active' : ''}}"
    data-val="all"
    bindtap="setDistrict"
  >全部区域</view>
  <view
    wx:for="{{districts}}"
    wx:key="*this"
    class="chip {{activeDistrict === item ? 'active' : ''}}"
    data-val="{{item}}"
    bindtap="setDistrict"
  >{{item}}</view>
</scroll-view>

<!-- Result count + sort -->
<view class="result-header">
  <text class="count">共 <text class="brand-green bold">{{filtered.length}}</text> 位老师</text>
  <picker bindchange="setSort" value="{{sortIdx}}" range="{{sortOptions}}">
    <view class="sort-picker">{{sortOptions[sortIdx]}} ▾</view>
  </picker>
</view>

<!-- Tutor cards -->
<view class="tutor-list">
  <view
    wx:for="{{filtered}}"
    wx:key="id"
    class="card tutor-card"
    data-id="{{item.id}}"
    bindtap="goTutor"
  >
    <view class="tutor-row">
      <view class="avatar-circle" style="background:{{item.color}}">{{item.name[0]}}</view>
      <view class="tutor-info">
        <view class="tutor-name">
          <text class="name-text">{{item.name}} 老师</text>
          <text wx:if="{{item.featured}}" class="badge-orange">⭐</text>
        </view>
        <view class="tutor-school">{{item.school}}</view>
        <view class="tutor-meta">
          <text class="rating">⭐ {{item.rating}}</text>
          <text> ({{item.reviews}}) · 教龄 {{item.years}} 年</text>
        </view>
      </view>
      <view
        class="fav-btn"
        catchtap="onToggleFav"
        data-id="{{item.id}}"
      >{{item.isFav ? '❤️' : '🤍'}}</view>
    </view>

    <view wx:if="{{item.books.length > 0}}" class="book-badge">
      📘 精通教材 {{item.books.length}} 本
    </view>

    <view class="tutor-footer">
      <view>
        <text class="price serif">¥{{item.price}}</text>
        <text class="price-l">/ 课时</text>
      </view>
      <text class="district">📍 {{item.district}}</text>
    </view>
  </view>
</view>

<view wx:if="{{filtered.length === 0}}" class="empty">
  <view class="empty-icon">🔍</view>
  <view class="empty-text">没有匹配的老师</view>
  <view class="empty-sub" bindtap="resetFilters">试试清除筛选</view>
</view>
