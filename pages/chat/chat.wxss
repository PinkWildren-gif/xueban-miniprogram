/* pages/chat/chat.wxss */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ---------- tutor mini-info strip ---------- */
.tutor-strip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-bottom: 1px solid #F3F4F6;
}

.strip-avatar {
  width: 72rpx;
  height: 72rpx;
  font-size: 32rpx;
  flex-shrink: 0;
}

.strip-info {
  flex: 1;
  min-width: 0;
}

.strip-name {
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.strip-meta {
  font-size: 22rpx;
  color: #6B7280;
}

.strip-price {
  color: #1a5d3a;
  font-size: 26rpx;
}

.strip-unit {
  color: #9CA3AF;
  margin-right: 12rpx;
}

.strip-rating {
  color: #D97706;
  font-weight: 600;
}

.strip-btn {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.strip-btn-fill {
  background: #1a5d3a;
  color: #ffffff;
}

.strip-btn-outline {
  background: #ffffff;
  color: #1a5d3a;
  border: 1px solid #1a5d3a;
}

/* ---------- message list ---------- */
.msg-scroll {
  flex: 1;
  height: 0; /* explicit flex-determined height for scroll-y */
}

.msg-list {
  padding: 24rpx 24rpx 32rpx;
}

.system-line {
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
  margin: 0 auto 24rpx;
  display: table; /* shrink to content width, centered */
}

.time-divider {
  text-align: center;
  font-size: 20rpx;
  color: #9CA3AF;
  margin: 24rpx 0 16rpx;
}

.msg-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.row-me {
  justify-content: flex-end;
}

.row-tutor {
  justify-content: flex-start;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}

.bubble {
  max-width: 480rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.bubble-me {
  background: #1a5d3a;
  color: #ffffff;
  border-radius: 20rpx 20rpx 6rpx 20rpx;
}

.bubble-tutor {
  background: #ffffff;
  color: #1F2937;
  border: 1px solid #F3F4F6;
  border-radius: 20rpx 20rpx 20rpx 6rpx;
}

.empty-hint {
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  padding: 80rpx 40rpx;
}

/* ---------- demo banner ---------- */
.demo-banner {
  background: #FEF3C7;
  color: #92400E;
  font-size: 20rpx;
  text-align: center;
  padding: 8rpx 24rpx;
}

/* ---------- input bar ---------- */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1px solid #F3F4F6;
}

.chat-input {
  flex: 1;
  background: #F3F4F6;
  border-radius: 999rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  box-sizing: content-box;
}

.send-btn {
  flex-shrink: 0;
  background: #1a5d3a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 36rpx;
  border-radius: 16rpx;
}

.send-disabled {
  background: #D1D5DB;
}
