/* pages/tutor-signup/tutor-signup.wxss */

.page-pad {
  padding-bottom: 60rpx;
}

/* ---------- hero ---------- */
.hero {
  text-align: center;
  padding: 16rpx 0 32rpx;
}

.hero-pill {
  display: inline-block;
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
  color: #1a5d3a;
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 38rpx;
  margin-bottom: 8rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: #6B7280;
}

/* ---------- stepper ---------- */
.stepper {
  display: flex;
  align-items: flex-start;
  background: #ffffff;
  border: 1px solid #FEF3C7;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 24rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 26rpx;
  background: #E5E7EB;
  color: #9CA3AF;
}

.step.active .step-dot {
  background: #1a5d3a;
  color: #ffffff;
  box-shadow: 0 0 0 8rpx rgba(26, 93, 58, 0.15);
}

.step.done .step-dot {
  background: #22C55E;
  color: #ffffff;
}

.step-label {
  font-size: 20rpx;
  color: #9CA3AF;
  white-space: nowrap;
}

.step.active .step-label {
  color: #1a5d3a;
  font-weight: 700;
}

.step.done .step-label {
  color: #6B7280;
}

.step-bar {
  flex: 1;
  height: 4rpx;
  background: #E5E7EB;
  margin: 26rpx 8rpx 0;
}

.step-bar.done {
  background: #22C55E;
}

/* ---------- panel head ---------- */
.panel-head {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.panel-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #DCFCE7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.panel-icon.red-bg {
  background: #FEF2F2;
}

.panel-head-text {
  flex: 1;
  min-width: 0;
}

.panel-step {
  font-size: 22rpx;
  color: #D97706;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.panel-title {
  font-size: 36rpx;
}

.panel-sub {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 6rpx;
  line-height: 1.5;
}

/* ---------- form fields ---------- */
.field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.field-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 10rpx;
}

.form-input {
  background: #F9FAFB;
  border: 1px solid #E5E7EB;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.ph {
  color: #9CA3AF;
}

.row-2 {
  display: flex;
  gap: 20rpx;
}

.col {
  flex: 1;
  min-width: 0;
}

.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #9CA3AF;
  font-size: 24rpx;
}

/* ---------- chips ---------- */
.chips-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 28rpx;
  border: 1px dashed #D1D5DB;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #4B5563;
  background: #ffffff;
}

.tag.selected {
  border-style: solid;
  border-color: #1a5d3a;
  background: #F0FDF4;
  color: #1a5d3a;
  font-weight: 600;
}

/* ---------- price ---------- */
.price-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.price-symbol {
  font-size: 36rpx;
  color: #1a5d3a;
}

.price-input {
  flex: 1;
}

.price-suffix {
  font-size: 24rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

/* ---------- textbook multi-select ---------- */
.books-field {
  border-top: 1px solid #F3F4F6;
  padding-top: 24rpx;
}

.books-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.books-label {
  margin-bottom: 0;
}

.books-toggle {
  font-size: 22rpx;
  color: #1a5d3a;
  font-weight: 600;
}

.book-search {
  margin-top: 20rpx;
}

.book-list {
  height: 480rpx;
  margin-top: 16rpx;
  border: 1px solid #F3F4F6;
  border-radius: 16rpx;
  background: #ffffff;
}

.book-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-bottom: 1px solid #F3F4F6;
}

.book-row.selected {
  background: #F0FDF4;
}

.book-spine {
  width: 36rpx;
  height: 48rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.book-title {
  flex: 1;
  font-size: 26rpx;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-check {
  color: #1a5d3a;
  font-weight: 700;
  font-size: 28rpx;
}

.book-empty {
  text-align: center;
  padding: 48rpx 0;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ---------- upload slots ---------- */
.upload-grid {
  display: flex;
  gap: 16rpx;
}

.upload-box {
  flex: 1;
  min-width: 0;
  border: 2rpx dashed #D1D5DB;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  background: #ffffff;
}

.upload-box.filled {
  border: 2rpx solid #86EFAC;
  background: #F0FDF4;
  padding: 12rpx;
}

.upload-icon {
  font-size: 44rpx;
  opacity: 0.4;
  margin-bottom: 8rpx;
}

.upload-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}

.upload-optional {
  font-size: 20rpx;
  color: #9CA3AF;
  font-weight: 400;
}

.upload-hint {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}

.upload-cta {
  font-size: 20rpx;
  color: #D97706;
  margin-top: 12rpx;
}

.upload-thumb {
  width: 100%;
  height: 160rpx;
  border-radius: 12rpx;
}

.upload-done {
  font-size: 22rpx;
  font-weight: 600;
  color: #1a5d3a;
  margin-top: 8rpx;
}

.demo-note {
  margin-top: 24rpx;
  background: #FEF3C7;
  border-left: 4rpx solid #F59E0B;
  padding: 14rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #92400E;
}

/* ---------- compliance pledges ---------- */
.rule-box {
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.rule-box.rule-red {
  background: #FEF2F2;
  border-left: 6rpx solid #EF4444;
}

.rule-box.rule-green {
  background: #F0FDF4;
  border-left: 6rpx solid #22C55E;
}

.rule-box-title {
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.rule-red .rule-box-title {
  color: #991B1B;
}

.rule-green .rule-box-title {
  color: #166534;
}

.rule-item {
  font-size: 22rpx;
  color: #4B5563;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.pledge-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.pledge-row.on {
  background: #F0FDF4;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #D1D5DB;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.checkbox.checked {
  background: #1a5d3a;
  border-color: #1a5d3a;
}

.pledge-text {
  flex: 1;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
}

.link {
  color: #1a5d3a;
  text-decoration: underline;
}

/* ---------- nav buttons ---------- */
.nav-row {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.nav-btn {
  flex: 1;
}

.nav-btn.disabled {
  opacity: 0.45;
}

.submit-note {
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 20rpx;
}

/* ---------- status / success screens ---------- */
.status-hero {
  text-align: center;
  padding: 56rpx 32rpx;
}

.status-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.status-chip {
  display: inline-block;
  margin-bottom: 20rpx;
}

.status-title {
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.status-sub {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.verify-row {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 20rpx;
}

.verify-item {
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  text-align: center;
}

.verify-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.verify-name {
  font-size: 22rpx;
  color: #1a5d3a;
  font-weight: 600;
}

.verify-note {
  font-size: 22rpx;
  color: #9CA3AF;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1px solid #F9FAFB;
}

.summary-row:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 24rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.summary-value {
  font-size: 24rpx;
  color: #374151;
  text-align: right;
}
