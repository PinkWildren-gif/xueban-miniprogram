/* pages/books/books.wxss */

/* ---- Header ---- */
.page-header {
  background: #ffffff;
  padding: 40rpx 32rpx 32rpx;
  border-bottom: 1px solid #FEF3C7;
}

.header-eyebrow {
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.header-title {
  font-size: 44rpx;
  color: #1a5d3a;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
}

.search-input {
  background: #F9FAFB;
  border: 1px solid #F3F4F6;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

/* ---- Sections ---- */
.sections {
  padding: 24rpx;
}

.section {
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.section-title {
  font-size: 34rpx;
  color: #1a5d3a;
}

.section-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ---- Book grid (2 columns) ---- */
.book-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.book-item {
  width: 47.5%;
  margin-bottom: 36rpx;
}

/* Book cover — gradient bg passed inline, spine highlight via ::before */
.book-cover {
  position: relative;
  height: 420rpx;
  border-radius: 8rpx 16rpx 16rpx 8rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

.book-cover::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 10rpx;
  background: linear-gradient(90deg, rgba(0, 0, 0, 0.35), transparent);
}

.cover-series {
  font-size: 20rpx;
  opacity: 0.85;
}

.cover-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.cover-subject {
  font-size: 48rpx;
  line-height: 1.2;
}

.cover-level {
  font-size: 32rpx;
  opacity: 0.92;
  margin-top: 8rpx;
}

.cover-hint {
  font-size: 20rpx;
  opacity: 0.8;
}

/* Below the cover */
.book-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-top: 16rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-tutors {
  text-align: center;
  margin-top: 8rpx;
}

/* ---- Empty search state ---- */
.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #1a5d3a;
  text-decoration: underline;
}

/* ---- Footer note ---- */
.footer-note {
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  padding: 16rpx 40rpx 60rpx;
}
