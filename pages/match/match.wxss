/* pages/match/match.wxss */

/* ===== Matched book header card ===== */

.book-card {
  position: relative;
}

.rescan {
  position: absolute;
  top: 28rpx;
  right: 32rpx;
  font-size: 24rpx;
  text-decoration: underline;
}

.book-row {
  display: flex;
  gap: 28rpx;
  align-items: flex-start;
}

.book-cover {
  width: 130rpx;
  height: 180rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 12rpx;
  box-sizing: border-box;
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
}

.cover-series {
  font-size: 18rpx;
  opacity: 0.85;
}

.cover-name {
  font-size: 26rpx;
  line-height: 1.3;
}

.book-info {
  flex: 1;
  min-width: 0;
}

.stamp-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.stamp {
  display: inline-block;
  border: 3rpx solid #D97706;
  color: #D97706;
  padding: 2rpx 16rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  transform: rotate(-3deg);
  font-size: 20rpx;
  border-radius: 4rpx;
}

.scan-time {
  font-size: 22rpx;
  color: #6B7280;
}

.book-title {
  font-size: 34rpx;
  line-height: 1.35;
  margin-bottom: 8rpx;
}

.book-isbn {
  font-size: 22rpx;
  color: #6B7280;
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.info-chip {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.chip-amber {
  background: #FFFBEB;
  color: #92400E;
}

.chip-green {
  background: #F0FDF4;
  color: #166534;
}

.chip-red {
  background: #FEF2F2;
  color: #B91C1C;
}

/* ===== Results header ===== */

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin: 8rpx 4rpx 24rpx;
}

.result-left {
  flex: 1;
  min-width: 0;
}

.result-title {
  font-size: 34rpx;
}

.result-sub {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}

.sort-picker {
  font-size: 24rpx;
  color: #1a5d3a;
  padding: 10rpx 20rpx;
  background: #ffffff;
  border: 1px solid #FDE68A;
  border-radius: 12rpx;
  white-space: nowrap;
}

/* ===== Tutor match cards ===== */

.match-card {
  padding: 28rpx;
}

.match-top {
  display: flex;
  gap: 24rpx;
}

.match-left {
  flex-shrink: 0;
  text-align: center;
  width: 120rpx;
}

.match-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 52rpx;
}

.match-pct-label {
  font-size: 18rpx;
  color: #9CA3AF;
  margin-top: 12rpx;
}

.match-pct {
  font-size: 32rpx;
  font-weight: 700;
}

.match-info {
  flex: 1;
  min-width: 0;
}

.match-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.match-name {
  font-weight: 700;
  font-size: 30rpx;
}

.match-dist {
  font-size: 20rpx;
  color: #6B7280;
  margin-left: auto;
  flex-shrink: 0;
}

.match-school {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.match-bar {
  height: 10rpx;
  border-radius: 5rpx;
  background: #E5E7EB;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.match-bar-fill {
  height: 100%;
  border-radius: 5rpx;
  background: linear-gradient(90deg, #16a34a, #D97706);
}

.book-exp {
  background: #FFFBEB;
  border-left: 6rpx solid #F59E0B;
  padding: 14rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.book-exp-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #78350F;
  margin-bottom: 4rpx;
}

.book-exp-text {
  font-size: 24rpx;
  color: #92400E;
}

.highlight {
  font-size: 24rpx;
  color: #4B5563;
  font-style: italic;
  margin-bottom: 16rpx;
  line-height: 1.55;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: #F0FDF4;
  color: #166534;
}

.tag-gift {
  background: #FEF2F2;
  color: #B91C1C;
  border: 1px solid #FECACA;
}

/* ===== Card footer ===== */

.match-footer {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1px solid #F3F4F6;
}

.meta-line {
  font-size: 22rpx;
  color: #B45309;
  margin-bottom: 6rpx;
}

.price-line {
  margin-bottom: 18rpx;
}

.price {
  font-size: 40rpx;
}

.price-l {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-left: 6rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-sm {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-sm-outline {
  background: #ffffff;
  color: #374151;
  border: 1px solid #E5E7EB;
}

.btn-sm-green {
  background: #1a5d3a;
  color: #ffffff;
}

/* ===== Empty state ===== */

.empty {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 32rpx;
}

.empty-btn {
  width: 360rpx;
  margin: 0 auto;
}

/* ===== Explainer ===== */

.explain-card {
  margin-top: 16rpx;
}

.explain-title {
  font-size: 30rpx;
  margin-bottom: 16rpx;
}

.explain-text {
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.7;
}

.explain-strong {
  font-weight: 700;
  color: #1f2937;
}
