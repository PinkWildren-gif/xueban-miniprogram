<!-- pages/my/my.wxml -->
<view class="user-card" bindtap="onEditName">
  <view class="user-avatar">{{avatarChar}}</view>
  <view class="user-text">
    <view class="user-name">{{displayName}} <text class="edit-hint">✏️</text></view>
    <view class="user-meta">{{profile.city}} · {{profile.district}} · {{roleLabel}}</view>
  </view>
</view>

<!-- 我的收藏 -->
<view class="menu-section">
  <view class="menu-title serif">❤️ 我的收藏 ({{favTutors.length}})</view>
  <view wx:if="{{favTutors.length > 0}}">
    <view
      wx:for="{{favTutors}}"
      wx:key="id"
      class="fav-row"
      data-id="{{item.id}}"
      bindtap="goTutor"
    >
      <view class="avatar-circle" style="background:{{item.color}}; width:72rpx; height:72rpx; font-size:32rpx">{{item.name[0]}}</view>
      <view class="fav-info">
        <view class="fav-name">{{item.name}} 老师</view>
        <view class="fav-school">{{item.school}}</view>
      </view>
      <view class="fav-price serif">¥{{item.price}}</view>
    </view>
  </view>
  <view wx:else class="empty-fav">
    还没有收藏的老师 · 去<text class="brand-green" bindtap="goTutors">找老师</text>
  </view>
</view>

<!-- 我的预约 -->
<view class="menu-section">
  <view class="menu-title serif">📅 我的预约 ({{requests.length}})</view>
  <view wx:if="{{requests.length > 0}}">
    <view
      wx:for="{{requests}}"
      wx:key="id"
      class="req-row"
      data-tutor-id="{{item.tutorId}}"
      bindtap="goRequestTutor"
    >
      <view class="req-info">
        <view class="req-top">
          <text class="req-name">{{item.tutorName}} 老师</text>
          <text class="{{item.status === 'pending' ? 'badge-orange' : 'badge-gray'}}">{{item.statusLabel}}</text>
        </view>
        <view class="req-sub">{{item.date}} {{item.time}} · {{item.mode}}</view>
        <view wx:if="{{item.note}}" class="req-note">留言：{{item.note}}</view>
      </view>
      <text
        wx:if="{{item.status === 'pending'}}"
        class="cancel-link"
        data-id="{{item.id}}"
        catchtap="onCancelRequest"
      >取消</text>
    </view>
  </view>
  <view wx:else class="empty-fav">
    暂无预约 · 试听 30 分钟免费
  </view>
</view>

<!-- 老师入驻 -->
<view class="menu-section apply-strip" bindtap="goTutorSignup">
  <view wx:if="{{hasApplication}}" class="apply-row">
    <text>👩‍🏫 我的入驻申请 · 审核中</text>
    <text class="row-arrow">›</text>
  </view>
  <view wx:else class="apply-row">
    <text>👩‍🏫 成为学伴老师 · 0抽成</text>
    <text class="row-arrow">›</text>
  </view>
</view>

<!-- 账户 -->
<view class="menu-section">
  <view class="menu-title serif">账户</view>
  <view class="menu-row" bindtap="onMyCourses"><text>📋 我的课程</text><text class="row-arrow">›</text></view>
  <view class="menu-row" bindtap="goMessages"><text>💬 消息</text><text class="row-arrow">›</text></view>
  <view class="menu-row" bindtap="onMembership"><text>💎 会员中心</text><text class="row-arrow">›</text></view>
  <view class="menu-row" bindtap="onInvite"><text>🎁 邀请好友</text><text class="row-arrow">›</text></view>
</view>

<!-- 帮助 -->
<view class="menu-section">
  <view class="menu-title serif">帮助</view>
  <view class="menu-row" bindtap="goCompliance"><text>🛡️ 合规披露</text><text class="row-arrow">›</text></view>
  <view class="menu-row" bindtap="goTerms"><text>📜 服务条款</text><text class="row-arrow">›</text></view>
  <view class="menu-row" bindtap="goPrivacy"><text>🔐 隐私政策</text><text class="row-arrow">›</text></view>
  <view class="menu-row" bindtap="onContact"><text>📞 联系客服</text><text class="row-arrow">›</text></view>
</view>

<view class="footer">
  学伴 XUEBAN · v0.2.0 (Alpha)
</view>
