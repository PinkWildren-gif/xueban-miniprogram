/* pages/my/my.wxss */

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #1a5d3a, #064E3B);
  color: #ffffff;
}

.user-avatar {
  width: 112rpx;
  height: 112rpx;
  background: #D97706;
  border-radius: 50%;
  color: #ffffff;
  font-weight: 700;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-text {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
}

.edit-hint {
  font-size: 24rpx;
  opacity: 0.7;
  margin-left: 8rpx;
}

.user-meta {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.menu-section {
  background: #ffffff;
  margin-top: 24rpx;
  padding: 24rpx;
}

.menu-title {
  font-weight: 700;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  color: #1f2937;
}

/* ---------- favorites ---------- */

.fav-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1px solid #F3F4F6;
}

.fav-row:last-child {
  border-bottom: none;
}

.fav-info {
  flex: 1;
}

.fav-name {
  font-weight: 600;
  font-size: 28rpx;
}

.fav-school {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

.fav-price {
  font-weight: 700;
  font-size: 32rpx;
  color: #1a5d3a;
}

.empty-fav {
  padding: 40rpx;
  text-align: center;
  color: #9CA3AF;
  font-size: 24rpx;
}

/* ---------- trial requests ---------- */

.req-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1px solid #F3F4F6;
}

.req-row:last-child {
  border-bottom: none;
}

.req-info {
  flex: 1;
}

.req-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.req-name {
  font-weight: 600;
  font-size: 28rpx;
}

.req-sub {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 6rpx;
}

.req-note {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.badge-gray {
  background: #F3F4F6;
  color: #6B7280;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.cancel-link {
  font-size: 24rpx;
  color: #9CA3AF;
  padding: 12rpx 16rpx;
}

/* ---------- tutor application strip ---------- */

.apply-strip {
  padding: 0 24rpx;
}

.apply-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a5d3a;
}

/* ---------- menu rows ---------- */

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1px solid #F3F4F6;
  font-size: 28rpx;
}

.menu-row:last-child {
  border-bottom: none;
}

.row-arrow {
  color: #D1D5DB;
  font-size: 32rpx;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  padding: 40rpx;
}

/* .brand-green comes from app.wxss — not redefined here */
