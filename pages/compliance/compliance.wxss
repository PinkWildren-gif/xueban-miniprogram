/* pages/compliance/compliance.wxss */

.legal-page {
  padding-bottom: 40rpx;
}

.page-header {
  text-align: center;
  padding: 40rpx 24rpx 36rpx;
}

.header-badge {
  display: inline-block;
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
  color: #1a5d3a;
  font-size: 22rpx;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 44rpx;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.page-intro {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.8;
  text-align: left;
}

.sec-card {
  padding: 36rpx 32rpx;
}

.sec-head {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid #F3F4F6;
}

.sec-num {
  font-size: 34rpx;
  color: #D97706;
}

.sec-title {
  font-size: 32rpx;
  color: #1a5d3a;
  flex: 1;
}

.body-text {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.9;
  margin-bottom: 16rpx;
}

.li {
  display: flex;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.li-dot {
  color: #1a5d3a;
  font-weight: 700;
  flex-shrink: 0;
}

.li-text {
  flex: 1;
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.8;
}

.strong {
  color: #1f2937;
  font-weight: 600;
}

.note {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.7;
  margin-top: 8rpx;
}

/* Policy explainer box */
.policy-box {
  background: #FEF2F2;
  border: 1px solid #FECACA;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.policy-title {
  font-size: 26rpx;
  color: #991B1B;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.policy-text {
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.8;
}

/* Can / cannot blocks */
.rule-block {
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.rule-block.ok {
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
}

.rule-block.no {
  background: #FEF2F2;
  border: 1px solid #FECACA;
}

.rule-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #166534;
  margin-bottom: 16rpx;
}

.rule-title.danger {
  color: #991B1B;
}

.ok-dot {
  color: #166534;
}

.no-dot {
  color: #DC2626;
}

/* Verification steps */
.step {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #1a5d3a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.step-body {
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 6rpx;
}

.step-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.7;
}

/* Report channel card */
.report-card {
  background: linear-gradient(135deg, #166534, #064E3B);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
  color: #ffffff;
}

.report-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.report-title {
  font-size: 38rpx;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.report-intro {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  margin-bottom: 24rpx;
  text-align: left;
}

.report-item {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.report-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 6rpx;
}

.report-value {
  font-size: 30rpx;
  font-weight: 700;
}

.report-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

/* ICP filing line */
.icp-line {
  font-size: 24rpx;
  color: #6B7280;
  background: #F9FAFB;
  border: 1px solid #E5E7EB;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  text-align: center;
  margin-bottom: 8rpx;
}

.link-row {
  font-size: 24rpx;
  color: #1a5d3a;
  text-decoration: underline;
  margin-top: 16rpx;
}

.page-footer {
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  padding: 40rpx 0 60rpx;
}
