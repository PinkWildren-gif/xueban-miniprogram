/* pages/index/index.wxss */

.hero {
  background: linear-gradient(180deg, #FFF3E0 0%, #FDF9F0 100%);
  padding: 48rpx 32rpx;
}

.tag {
  display: inline-block;
  background: #FEF3C7;
  color: #92400E;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  margin-bottom: 32rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 16rpx;
  color: #1f2937;
}

.hero-sub {
  color: #6b7280;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.bold {
  font-weight: 700;
  color: #D97706;
}

.scan-btn {
  margin-bottom: 16rpx;
  font-size: 32rpx;
}

.stats {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 32rpx;
  background: #ffffff;
  margin-bottom: 24rpx;
}

.stat {
  text-align: center;
}

.stat-n {
  font-size: 52rpx;
  font-weight: 700;
}

.stat-l {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.section-more {
  font-size: 24rpx;
  color: #1a5d3a;
}

.tutor-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.tutor-card {
  padding: 24rpx;
}

.tutor-row {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tutor-info {
  flex: 1;
}

.tutor-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.name-text {
  font-weight: 700;
  font-size: 30rpx;
}

.tutor-school {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 6rpx;
}

.tutor-meta {
  font-size: 22rpx;
  color: #6b7280;
}

.rating {
  color: #D97706;
  font-weight: 600;
}

.tutor-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.tutor-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 16rpx;
  border-top: 1px solid #F3F4F6;
}

.price {
  font-size: 36rpx;
  font-weight: 700;
}

.price-l {
  font-size: 22rpx;
  color: #9CA3AF;
}

.district {
  font-size: 22rpx;
  color: #6b7280;
}

.compliance {
  display: flex;
  gap: 16rpx;
  margin: 24rpx;
  padding: 24rpx;
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
  border-radius: 16rpx;
}

.compliance-icon {
  font-size: 40rpx;
}

.compliance-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #166534;
  margin-bottom: 4rpx;
}

.compliance-sub {
  font-size: 22rpx;
  color: #6b7280;
}

.footer {
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  padding: 32rpx;
}
