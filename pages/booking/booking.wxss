/* pages/booking/booking.wxss */

/* ---- tutor summary card ---- */
.tutor-summary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}

.summary-info {
  flex: 1;
  min-width: 0;
}

.summary-name {
  font-weight: 700;
  font-size: 30rpx;
  margin-bottom: 4rpx;
}

.summary-school {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-meta {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 22rpx;
}

.summary-price {
  font-size: 32rpx;
  color: #1a5d3a;
}

.summary-price-l {
  font-size: 22rpx;
  color: #9CA3AF;
}

.summary-rating {
  margin-left: 12rpx;
  color: #D97706;
  font-weight: 600;
}

/* ---- compliance banner ---- */
.compliance-banner {
  background: #FFFBEB;
  border: 1px solid #FDE68A;
  border-left: 6rpx solid #F59E0B;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: #92400E;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

/* ---- section titles ---- */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin: 8rpx 0 16rpx;
}

.section-hint {
  font-size: 22rpx;
  font-weight: 400;
  color: #9CA3AF;
}

/* ---- date strip ---- */
.date-strip {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.date-chip {
  display: inline-block;
  text-align: center;
  background: #ffffff;
  border: 1px solid #E5E7EB;
  border-radius: 16rpx;
  padding: 16rpx 22rpx;
  margin-right: 12rpx;
}

.date-weekday {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 4rpx;
}

.date-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.date-active {
  background: #1a5d3a;
  border-color: #1a5d3a;
}

.date-active .date-weekday,
.date-active .date-label {
  color: #ffffff;
}

.date-disabled {
  background: #F3F4F6;
  border-color: #E5E7EB;
}

.date-disabled .date-weekday,
.date-disabled .date-label {
  color: #C0C4CC;
}

.date-ban {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #991B1B;
  background: #FEE2E2;
  border-radius: 999rpx;
  padding: 2rpx 10rpx;
}

/* ---- time slot grid ---- */
.slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.slot-chip {
  width: calc(25% - 12rpx);
  box-sizing: border-box;
  text-align: center;
  background: #ffffff;
  border: 1px solid #E5E7EB;
  border-radius: 12rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #1f2937;
}

.slot-active {
  background: #1a5d3a;
  border-color: #1a5d3a;
  color: #ffffff;
  font-weight: 600;
}

/* ---- mode selector ---- */
.mode-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mode-chip {
  background: #ffffff;
  border: 1px solid #E5E7EB;
  border-radius: 999rpx;
  padding: 14rpx 32rpx;
  font-size: 26rpx;
  color: #4B5563;
}

.mode-active {
  background: #1a5d3a;
  border-color: #1a5d3a;
  color: #ffffff;
  font-weight: 600;
}

/* ---- note ---- */
.note-box {
  background: #ffffff;
  border: 1px solid #FEF3C7;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.note-input {
  width: 100%;
  height: 160rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.note-placeholder {
  color: #C0C4CC;
}

.note-counter {
  text-align: right;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

/* ---- price box ---- */
.price-box {
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.price-trial {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a5d3a;
  margin-bottom: 6rpx;
}

.price-formal {
  font-size: 22rpx;
  color: #4B5563;
}

/* ---- submit ---- */
.submit-btn {
  margin-bottom: 16rpx;
}

.submit-disabled {
  background: #9CA3AF;
  opacity: 0.7;
}

.submit-hint {
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
  padding-bottom: 40rpx;
}

/* ---- success view ---- */
.success-wrap {
  padding: 120rpx 48rpx;
  text-align: center;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.success-title {
  font-size: 40rpx;
  color: #1a5d3a;
  margin-bottom: 16rpx;
}

.success-summary {
  display: inline-block;
  background: #F0FDF4;
  color: #166534;
  border-radius: 999rpx;
  padding: 8rpx 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.success-sub {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.7;
  margin-bottom: 56rpx;
}

.success-btn {
  margin-bottom: 24rpx;
}

.slot-empty {
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}
