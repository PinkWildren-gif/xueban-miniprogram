<!-- pages/tutor-detail/tutor-detail.wxml -->
<view wx:if="{{tutor}}">

  <!-- Hero -->
  <view class="hero">
    <view class="hero-top">
      <view class="big-avatar" style="background:{{tutor.color}}">{{tutor.name[0]}}</view>
      <view class="fav-big" bindtap="onToggleFav">{{isFav ? '❤️' : '🤍'}}</view>
    </view>
    <view class="hero-name-row">
      <text class="hero-name serif">{{tutor.name}} 老师</text>
      <text wx:if="{{tutor.featured}}" class="badge-orange">⭐ 推荐</text>
    </view>
    <view class="hero-school">{{tutor.school}} · {{tutor.title}}</view>
    <view class="hero-meta">
      <text class="rating">⭐ {{tutor.rating}}</text>
      <text> ({{tutor.reviews}} 条) · 教龄 {{tutor.years}} 年 · 已教 {{tutor.students}}+ 学生</text>
    </view>
    <view class="hero-tags">
      <text
        wx:for="{{tutor.tags}}"
        wx:key="*this"
        class="badge-green"
      >{{item}}</text>
    </view>
  </view>

  <view class="detail-body">

  <!-- Bio -->
  <view class="card">
    <view class="section-title serif">老师简介</view>
    <view class="bio">{{tutor.bio}}</view>
    <view class="meta-grid">
      <view class="meta-box">
        <view class="meta-label">教学风格</view>
        <view class="meta-value">{{tutor.style}}</view>
      </view>
      <view class="meta-box">
        <view class="meta-label">适合年级</view>
        <view class="meta-value">{{tutor.grades}}</view>
      </view>
      <view class="meta-box">
        <view class="meta-label">授课方式</view>
        <view class="meta-value">{{tutor.mode}}</view>
      </view>
      <view class="meta-box">
        <view class="meta-label">所在区域</view>
        <view class="meta-value">📍 {{tutor.district}}</view>
      </view>
    </view>
  </view>

  <!-- Books taught -->
  <view wx:if="{{tutor.books.length > 0}}" class="card">
    <view class="section-title serif">📘 教过的教材 ({{tutor.books.length}})</view>
    <view class="section-sub">扫描这些课本，{{tutor.name}}老师会被优先推荐</view>
    <view class="book-grid">
      <view
        wx:for="{{tutor.books}}"
        wx:key="*this"
        class="book-item"
        data-key="{{item}}"
        bindtap="goBook"
      >
        <text>📖 {{item}}</text>
        <text class="book-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Credentials -->
  <view class="card">
    <view class="section-title serif">资质证书</view>
    <view class="cred-grid">
      <view
        wx:for="{{tutor.verified}}"
        wx:key="*this"
        class="cred-item"
      >✓ {{item}}</view>
    </view>
    <view class="section-sub">所有资质均经学伴人工核验。平台通过率仅 68%。</view>
  </view>

  <!-- Parent reviews -->
  <view class="card">
    <view class="section-title serif">近期家长评价 ({{reviewCount}})</view>
    <view wx:if="{{reviewCount === 0}}" class="review-empty">历史评价整理中，敬请期待</view>
    <block wx:else>
      <view
        wx:for="{{showAllReviews ? reviewsFull : reviewsPreview}}"
        wx:key="idx"
        class="review-item {{index === lastReviewIndex ? 'review-item-last' : ''}}"
      >
        <view class="review-head">
          <view class="review-parent">
            <view class="review-avatar">{{item.parent[0]}}</view>
            <text class="review-name">{{item.parent}}</text>
          </view>
          <text class="review-date">{{item.date}}</text>
        </view>
        <view class="review-stars">{{item.stars}}</view>
        <view class="review-text">{{item.text}}</view>
      </view>
      <view
        wx:if="{{reviewCount > 3}}"
        class="review-toggle"
        bindtap="toggleReviews"
      >{{showAllReviews ? '收起评价' : '查看全部 ' + reviewCount + ' 条评价'}}</view>
    </block>
  </view>

  </view>

  <!-- Compliance callout -->
  <view class="compliance-card">
    <view class="compliance-title">🛡️ 双减政策合规提示</view>
    <view class="compliance-text">{{complianceText}}</view>
  </view>

  <!-- Sticky CTA -->
  <view class="cta-bar">
    <view class="cta-price">
      <text class="price-big serif">¥{{tutor.price}}</text>
      <text class="price-unit">/ 课时</text>
    </view>
    <view class="btn-secondary cta-btn cta-btn-trial" bindtap="onBookTrial">预约试听</view>
    <view class="btn-primary cta-btn cta-btn-contact" bindtap="onContact">💬 联系老师</view>
  </view>
</view>

<view wx:else class="loading">加载中...</view>
