/* pages/tutor-detail/tutor-detail.wxss */

.hero {
  background: #ffffff;
  padding: 32rpx 24rpx;
  margin-bottom: 16rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.big-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 72rpx;
  font-weight: 700;
}

.fav-big {
  font-size: 48rpx;
  padding: 16rpx;
}

.hero-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.hero-name {
  font-size: 48rpx;
  font-weight: 700;
}

.hero-school {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.hero-meta {
  font-size: 22rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.rating {
  color: #D97706;
  font-weight: 600;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.section-sub {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 16rpx;
}

.bio {
  font-size: 28rpx;
  line-height: 1.7;
  color: #374151;
  margin-bottom: 20rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.meta-box {
  background: #F9FAFB;
  padding: 16rpx;
  border-radius: 12rpx;
}

.meta-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 26rpx;
  font-weight: 600;
}

.book-grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.book-item {
  background: #FEF3C7;
  border: 1px solid #FCD34D;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #92400E;
}

.cred-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cred-item {
  background: #F0FDF4;
  border: 1px solid #BBF7D0;
  color: #166534;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.compliance-card {
  margin: 24rpx;
  background: #FEF2F2;
  border: 1px solid #FECACA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.compliance-title {
  font-weight: 600;
  color: #991B1B;
  margin-bottom: 8rpx;
  font-size: 26rpx;
}

.compliance-text {
  font-size: 22rpx;
  color: #7F1D1D;
  line-height: 1.6;
}

.cta-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-top: 1px solid #F3F4F6;
  padding: 20rpx 24rpx env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 100;
}

.cta-price {
  flex-shrink: 0;
}

.price-big {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
}

.price-unit {
  font-size: 22rpx;
  color: #9CA3AF;
}

.cta-btn {
  flex: 1;
  margin: 0;
}

.loading {
  text-align: center;
  padding: 200rpx;
  color: #9CA3AF;
}
